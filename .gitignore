# macOS
.DS_Store
**/.DS_Store

# Temporary video-rendering output (generated by render-video.js)
.video-tmp-*/
**/.video-tmp-*/

# Personal asset index (private user data; keep only the .example.json template)
assets/personal-asset-index.json

# Environment variables (API keys and other secrets; keep only the .env.example template)
.env
.env.local

# Voiceover work directory (regenerable TTS MP3 and timeline.json artifacts)
**/_narration/
**/_narration_*/

# Node / editor / OS
node_modules/
*.swp
.idea/
.vscode/
Thumbs.db

# Verification artifacts (screenshots and temporary test scripts)
demos/_frames_*.png
demos/_verify.js
demos/_verify.mjs

# Development and test artifacts (internal skill development only; not distributed to users)
_style-research/
**/design-demos/

# Large demo videos (distributed through GitHub Releases to keep the repository small)
demos/**/*.mp4
